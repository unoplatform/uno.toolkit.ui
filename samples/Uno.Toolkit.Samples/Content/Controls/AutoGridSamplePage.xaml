<Page x:Class="Uno.Toolkit.Samples.Content.Controls.AutoGridSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	  xmlns:utu="using:Uno.Toolkit.UI"
	  mc:Ignorable="d">

	<Grid Background="{ThemeResource SurfaceBrush}"
		  RowSpacing="16"
		  Padding="16">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!--  Controls  -->
		<StackPanel Spacing="8">

			<StackPanel Orientation="Horizontal"
						Spacing="16"
						VerticalAlignment="Center">
				<TextBlock Text="Mode:"
						   VerticalAlignment="Center" />
				<ComboBox x:Name="ModeComboBox"
						  SelectionChanged="OnModeChanged" />
			</StackPanel>

			<StackPanel Orientation="Horizontal"
						Spacing="16"
						VerticalAlignment="Center">
				<TextBlock Text="Columns:"
						   VerticalAlignment="Center" />
				<TextBox x:Name="ColumnsTextBox"
						 MinWidth="160"
						 PlaceholderText="e.g. *,*,*"
						 TextChanged="OnColumnsTextChanged" />
				<TextBlock Text="Rows:"
						   VerticalAlignment="Center" />
				<TextBox x:Name="RowsTextBox"
						 MinWidth="160"
						 PlaceholderText="e.g. Auto,Auto"
						 TextChanged="OnRowsTextChanged" />
			</StackPanel>

			<StackPanel Orientation="Horizontal"
						Spacing="8">
				<Button Click="OnAddClick"
						Content="Add" />
				<Button Click="OnRemoveClick"
						Content="Remove" />
				<Button Click="OnResetClick"
						Content="Reset" />
			</StackPanel>

		</StackPanel>

		<!--  Demo Grid  -->
		<Border Grid.Row="1"
				BorderBrush="{ThemeResource OutlineVariantBrush}"
				BorderThickness="1">
			<Grid x:Name="DemoGrid" />
		</Border>

	</Grid>
</Page>
