<Page
	x:Class="Uno.Toolkit.RuntimeTests.Tests.TestPages.DrawerFlyoutPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:utu="using:Uno.Toolkit.UI"
	Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Grid Padding="12">
		<Button x:Name="OpenButton" Content="Open Drawer">
			<Button.Flyout>
				<Flyout utu:DrawerFlyoutPresenter.OpenDirection="Left" utu:DrawerFlyoutPresenter.DrawerLength="300" utu:DrawerFlyoutPresenter.IsGestureEnabled="True">
					<TextBlock x:Name="DrawerContent" Text="Drawer content" />
				</Flyout>
			</Button.Flyout>
		</Button>
	</Grid>
</Page>
