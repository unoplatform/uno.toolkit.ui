<Page
	x:Class="Uno.Toolkit.RuntimeTests.Tests.TestPages.TabBarPage5"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:utu="using:Uno.Toolkit.UI"
	Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
	mc:Ignorable="d">

	<Grid Padding="12">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<utu:TabBar x:Name="TB" Grid.Row="0" SelectedIndex="0">
			<utu:TabBar.Items>
				<utu:TabBarItem Content="Tab One" utu:TabBarItemExtensions.OnClickBehaviors="ScrollToTop" />
				<utu:TabBarItem Content="Tab Two" />
			</utu:TabBar.Items>
		</utu:TabBar>

		<ScrollViewer x:Name="SV" Grid.Row="1" Height="200">
			<StackPanel>
				<Rectangle Height="100" Fill="Red" />
				<Rectangle Height="100" Fill="Green" />
				<Rectangle Height="100" Fill="Blue" />
				<Rectangle Height="100" Fill="Yellow" />
				<Rectangle Height="100" Fill="Purple" />
			</StackPanel>
		</ScrollViewer>
	</Grid>
</Page>
