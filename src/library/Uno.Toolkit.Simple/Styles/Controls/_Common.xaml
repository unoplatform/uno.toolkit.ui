<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:utu="using:Uno.Toolkit.UI"
					xmlns:toolkit="using:Uno.UI.Toolkit">

	<!-- Implicit styles -->
	<Style BasedOn="{StaticResource SimpleDefaultDividerStyle}" TargetType="utu:Divider" />
	<Style BasedOn="{StaticResource SimpleDefaultNavigationBarStyle}" TargetType="utu:NavigationBar" />
	<Style BasedOn="{StaticResource SimpleDefaultMainCommandStyle}" TargetType="AppBarButton" />
	<Style BasedOn="{StaticResource SimpleDefaultChipStyle}" TargetType="utu:Chip" />

	<!-- Implicit styles aliases -->
	<StaticResource x:Key="DividerStyle" ResourceKey="SimpleDividerStyle" />
	<StaticResource x:Key="NavigationBarStyle" ResourceKey="SimpleNavigationBarStyle" />
	<StaticResource x:Key="MainCommandStyle" ResourceKey="SimpleMainCommandStyle" />
	<StaticResource x:Key="ChipStyle" ResourceKey="SimpleChipStyle" />

	<!-- Other resources aliases -->
	<StaticResource x:Key="ModalNavigationBarStyle" ResourceKey="SimpleModalNavigationBarStyle" />
	<StaticResource x:Key="PrimaryNavigationBarStyle" ResourceKey="SimplePrimaryNavigationBarStyle" />
	<StaticResource x:Key="PrimaryModalNavigationBarStyle" ResourceKey="SimplePrimaryModalNavigationBarStyle" />
	<StaticResource x:Key="ModalMainCommandStyle" ResourceKey="SimpleModalMainCommandStyle" />
	<StaticResource x:Key="PrimaryMainCommandStyle" ResourceKey="SimplePrimaryMainCommandStyle" />
	<StaticResource x:Key="PrimaryModalMainCommandStyle" ResourceKey="SimplePrimaryModalMainCommandStyle" />
	<StaticResource x:Key="PrimaryAppBarButtonStyle" ResourceKey="SimplePrimaryAppBarButtonStyle" />
	<StaticResource x:Key="TopTabBarStyle" ResourceKey="SimpleTopTabBarStyle" />
	<StaticResource x:Key="ColoredTopTabBarStyle" ResourceKey="SimpleColoredTopTabBarStyle" />
	<StaticResource x:Key="TopTabBarItemStyle" ResourceKey="SimpleTopTabBarItemStyle" />
	<StaticResource x:Key="ColoredTopTabBarItemStyle" ResourceKey="SimpleColoredTopTabBarItemStyle" />
	<StaticResource x:Key="ElevatedSuggestionChipStyle" ResourceKey="SimpleElevatedSuggestionChipStyle" />
	<StaticResource x:Key="SuggestionChipStyle" ResourceKey="SimpleSuggestionChipStyle" />
	<StaticResource x:Key="InputChipStyle" ResourceKey="SimpleInputChipStyle" />
	<StaticResource x:Key="ElevatedFilterChipStyle" ResourceKey="SimpleElevatedFilterChipStyle" />
	<StaticResource x:Key="FilterChipStyle" ResourceKey="SimpleFilterChipStyle" />
	<StaticResource x:Key="ElevatedAssistChipStyle" ResourceKey="SimpleElevatedAssistChipStyle" />
	<StaticResource x:Key="AssistChipStyle" ResourceKey="SimpleAssistChipStyle" />
	<StaticResource x:Key="ElevatedSuggestionChipGroupStyle" ResourceKey="SimpleElevatedSuggestionChipGroupStyle" />
	<StaticResource x:Key="SuggestionChipGroupStyle" ResourceKey="SimpleSuggestionChipGroupStyle" />
	<StaticResource x:Key="InputChipGroupStyle" ResourceKey="SimpleInputChipGroupStyle" />
	<StaticResource x:Key="ElevatedFilterChipGroupStyle" ResourceKey="SimpleElevatedFilterChipGroupStyle" />
	<StaticResource x:Key="FilterChipGroupStyle" ResourceKey="SimpleFilterChipGroupStyle" />
	<StaticResource x:Key="ElevatedAssistChipGroupStyle" ResourceKey="SimpleElevatedAssistChipGroupStyle" />
	<StaticResource x:Key="AssistChipGroupStyle" ResourceKey="SimpleAssistChipGroupStyle" />
	<StaticResource x:Key="BottomTabBarStyle" ResourceKey="SimpleBottomTabBarStyle" />
	<StaticResource x:Key="BottomTabBarItemStyle" ResourceKey="SimpleBottomTabBarItemStyle" />
	<StaticResource x:Key="BottomFabTabBarItemStyle" ResourceKey="SimpleBottomFabTabBarItemStyle" />
	<StaticResource x:Key="OutlinedCardStyle" ResourceKey="SimpleOutlinedCardStyle" />
	<StaticResource x:Key="FilledCardStyle" ResourceKey="SimpleFilledCardStyle" />
	<StaticResource x:Key="ElevatedCardStyle" ResourceKey="SimpleElevatedCardStyle" />
	<StaticResource x:Key="AvatarOutlinedCardStyle" ResourceKey="SimpleAvatarOutlinedCardStyle" />
	<StaticResource x:Key="AvatarFilledCardStyle" ResourceKey="SimpleAvatarFilledCardStyle" />
	<StaticResource x:Key="AvatarElevatedCardStyle" ResourceKey="SimpleAvatarElevatedCardStyle" />
	<StaticResource x:Key="SmallMediaOutlinedCardStyle" ResourceKey="SimpleSmallMediaOutlinedCardStyle" />
	<StaticResource x:Key="SmallMediaFilledCardStyle" ResourceKey="SimpleSmallMediaFilledCardStyle" />
	<StaticResource x:Key="SmallMediaElevatedCardStyle" ResourceKey="SimpleSmallMediaElevatedCardStyle" />
	<StaticResource x:Key="BrandFilledCardStyle" ResourceKey="SimpleBrandFilledCardStyle" />
	<StaticResource x:Key="BrandOutlinedCardStyle" ResourceKey="SimpleBrandOutlinedCardStyle" />
	<StaticResource x:Key="OutlinedCardContentControlStyle" ResourceKey="SimpleOutlinedCardContentControlStyle" />
	<StaticResource x:Key="FilledCardContentControlStyle" ResourceKey="SimpleFilledCardContentControlStyle" />
	<StaticResource x:Key="ElevatedCardContentControlStyle" ResourceKey="SimpleElevatedCardContentControlStyle" />
	<StaticResource x:Key="DangerChipStyle" ResourceKey="SimpleDangerChipStyle" />
<StaticResource x:Key="VerticalTabBarStyle" ResourceKey="SimpleVerticalTabBarStyle" />
	<StaticResource x:Key="VerticalTabBarItemStyle" ResourceKey="SimpleVerticalTabBarItemStyle" />
	<StaticResource x:Key="FabTabBarItemStyle" ResourceKey="SimpleFabTabBarItemStyle" />
	<StaticResource x:Key="NavigationTabBarItemStyle" ResourceKey="SimpleNavigationTabBarItemStyle" />
</ResourceDictionary>
