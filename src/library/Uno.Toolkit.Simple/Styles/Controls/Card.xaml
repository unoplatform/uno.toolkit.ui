<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:utu="using:Uno.Toolkit.UI">

	<ResourceDictionary.ThemeDictionaries>

		<!--  ─── Light Theme ───  -->
		<ResourceDictionary x:Key="Light">
			<!--  Default Card  -->
			<StaticResource x:Key="SimpleCardBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleCardBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultDefaultHoverBrush" />
			<StaticResource x:Key="SimpleCardBorderBrush" ResourceKey="SimpleBorderDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleCardForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleCardSecondaryForeground" ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleCardBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleCardForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!--  Brand Card  -->
			<StaticResource x:Key="SimpleBrandCardBackground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleBrandCardBackgroundPointerOver" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleBrandCardForeground" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleBrandCardSecondaryForeground" ResourceKey="SimpleTextBrandOnBrandBrush" />
		</ResourceDictionary>

		<!--  ─── Dark Theme (Default) ───  -->
		<ResourceDictionary x:Key="Default">
			<!--  Default Card  -->
			<StaticResource x:Key="SimpleCardBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleCardBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultDefaultHoverBrush" />
			<StaticResource x:Key="SimpleCardBorderBrush" ResourceKey="SimpleBorderDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleCardForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleCardSecondaryForeground" ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleCardBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleCardForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!--  Brand Card  -->
			<StaticResource x:Key="SimpleBrandCardBackground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleBrandCardBackgroundPointerOver" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleBrandCardForeground" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleBrandCardSecondaryForeground" ResourceKey="SimpleTextBrandOnBrandBrush" />
		</ResourceDictionary>
	</ResourceDictionary.ThemeDictionaries>

	<CornerRadius x:Key="SimpleCardCornerRadius">8</CornerRadius>
	<Thickness x:Key="SimpleCardPadding">24</Thickness>
	<Thickness x:Key="SimpleCardBorderThickness">1</Thickness>
	<x:Double x:Key="SimpleCardMinWidth">240</x:Double>
	<x:Double x:Key="SimpleCardMaxWidth">440</x:Double>

	<CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
	<Thickness x:Key="CardPadding">24</Thickness>
	<Thickness x:Key="CardBorderThickness">1</Thickness>
	<x:Double x:Key="CardMinHeight">72</x:Double>
	<x:Double x:Key="CardMaxWidth">440</x:Double>
	<x:Double x:Key="CardElevation">0</x:Double>
	<Thickness x:Key="CardElevationMargin">0</Thickness>

	<DataTemplate x:Key="SimpleDefaultHeaderContentTemplate">
		<TextBlock
			Margin="0,0,0,8"
			FontSize="24"
			FontWeight="SemiBold"
			Foreground="{ThemeResource SimpleCardForeground}"
			MaxLines="1"
			Text="{Binding}" />
	</DataTemplate>

	<DataTemplate x:Key="SimpleDefaultSubHeaderContentTemplate">
		<TextBlock
			FontSize="16"
			Foreground="{ThemeResource SimpleCardSecondaryForeground}"
			MaxLines="2"
			Text="{Binding}" />
	</DataTemplate>

	<DataTemplate x:Key="SimpleDefaultSupportingContentTemplate">
		<TextBlock
			FontSize="16"
			Foreground="{ThemeResource SimpleCardSecondaryForeground}"
			Text="{Binding}"
			TextWrapping="Wrap" />
	</DataTemplate>

	<DataTemplate x:Key="SimpleDefaultMediaContentTemplate">
		<Border MinHeight="160" CornerRadius="8">
			<Image Source="{Binding}" Stretch="UniformToFill" />
		</Border>
	</DataTemplate>

	<DataTemplate x:Key="SimpleDefaultAvatarContentTemplate">
		<Image
			MaxWidth="40"
			MaxHeight="40"
			Source="{Binding}"
			Stretch="Uniform" />
	</DataTemplate>

	<DataTemplate x:Key="SimpleDefaultAvatarSupportingContentTemplate">
		<TextBlock
			FontSize="16"
			Foreground="{ThemeResource SimpleCardSecondaryForeground}"
			Text="{Binding}"
			TextWrapping="Wrap" />
	</DataTemplate>

	<DataTemplate x:Key="SimpleDefaultSmallMediaSupportingContentTemplate">
		<TextBlock
			FontSize="16"
			Foreground="{ThemeResource SimpleCardSecondaryForeground}"
			Text="{Binding}"
			TextWrapping="Wrap" />
	</DataTemplate>

	<DataTemplate x:Key="SimpleDefaultSmallMediaContentTemplate">
		<Border MaxHeight="94" CornerRadius="8">
			<Image
				VerticalAlignment="Top"
				Source="{Binding}"
				Stretch="UniformToFill" />
		</Border>
	</DataTemplate>

	<Style x:Key="SimpleBaseCardStyle" TargetType="utu:Card">
		<Setter Property="MinWidth" Value="{StaticResource SimpleCardMinWidth}" />
		<Setter Property="MaxWidth" Value="{StaticResource SimpleCardMaxWidth}" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleCardCornerRadius}" />
		<Setter Property="Padding" Value="{StaticResource SimpleCardPadding}" />
		<Setter Property="Background" Value="{ThemeResource SimpleCardBackground}" />
		<Setter Property="Foreground" Value="{ThemeResource SimpleCardForeground}" />
		<Setter Property="FontFamily" Value="{StaticResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="16" />
		<Setter Property="HeaderContentTemplate" Value="{StaticResource SimpleDefaultHeaderContentTemplate}" />
		<Setter Property="SubHeaderContentTemplate" Value="{StaticResource SimpleDefaultSubHeaderContentTemplate}" />
		<Setter Property="SupportingContentTemplate" Value="{StaticResource SimpleDefaultSupportingContentTemplate}" />
		<Setter Property="MediaContentTemplate" Value="{StaticResource SimpleDefaultMediaContentTemplate}" />
		<Setter Property="AvatarContentTemplate" Value="{StaticResource SimpleDefaultAvatarContentTemplate}" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="HorizontalContentAlignment" Value="Stretch" />
		<Setter Property="IsClickable" Value="False" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="utu:Card">
					<Grid
						x:Name="GridRoot"
						MinWidth="{TemplateBinding MinWidth}"
						MinHeight="{TemplateBinding MinHeight}"
						MaxWidth="{TemplateBinding MaxWidth}"
						MaxHeight="{TemplateBinding MaxHeight}"
						Padding="{TemplateBinding Padding}"
						HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
						Background="{TemplateBinding Background}"
						BorderBrush="{TemplateBinding BorderBrush}"
						BorderThickness="{TemplateBinding BorderThickness}"
						CornerRadius="{TemplateBinding CornerRadius}">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>

						<!--  Media content  -->
						<ContentPresenter
							x:Name="MediaContentPresenter"
							Margin="0,0,0,24"
							HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
							AutomationProperties.AccessibilityView="Raw"
							Content="{TemplateBinding MediaContent}"
							ContentTemplate="{TemplateBinding MediaContentTemplate}"
							IsHitTestVisible="False"
							Visibility="{Binding MediaContent, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource EmptyOrNullToCollapsedConverter}}" />

						<!--  Avatar  -->
						<ContentPresenter
							x:Name="AvatarContentPresenter"
							Grid.Row="1"
							Margin="0,0,0,8"
							AutomationProperties.AccessibilityView="Raw"
							Content="{TemplateBinding AvatarContent}"
							ContentTemplate="{TemplateBinding AvatarContentTemplate}"
							IsHitTestVisible="False"
							Visibility="{Binding AvatarContent, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource EmptyOrNullToCollapsedConverter}}" />

						<!--  Header  -->
						<ContentPresenter
							x:Name="HeaderContentPresenter"
							Grid.Row="2"
							HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
							AutomationProperties.AccessibilityView="Raw"
							Content="{TemplateBinding HeaderContent}"
							ContentTemplate="{TemplateBinding HeaderContentTemplate}"
							Visibility="{Binding HeaderContent, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource EmptyOrNullToCollapsedConverter}}" />

						<!--  SubHeader  -->
						<ContentPresenter
							x:Name="SubHeaderContentPresenter"
							Grid.Row="3"
							HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
							AutomationProperties.AccessibilityView="Raw"
							Content="{TemplateBinding SubHeaderContent}"
							ContentTemplate="{TemplateBinding SubHeaderContentTemplate}"
							Visibility="{Binding SubHeaderContent, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource EmptyOrNullToCollapsedConverter}}" />

						<!--  Supporting Content  -->
						<ContentPresenter
							x:Name="SupportingContentPresenter"
							Grid.Row="4"
							Margin="0,24,0,0"
							HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
							AutomationProperties.AccessibilityView="Raw"
							Content="{TemplateBinding SupportingContent}"
							ContentTemplate="{TemplateBinding SupportingContentTemplate}"
							Visibility="{Binding SupportingContent, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource EmptyOrNullToCollapsedConverter}}" />

						<!--  Icons  -->
						<ContentPresenter
							x:Name="IconsContentPresenter"
							Grid.Row="5"
							HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
							AutomationProperties.AccessibilityView="Raw"
							Content="{TemplateBinding IconsContent}"
							ContentTemplate="{TemplateBinding IconsContentTemplate}"
							Visibility="{Binding IconsContentTemplate, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToCollapsedConverter}}" />

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />
								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="GridRoot.Background" Value="{ThemeResource SimpleCardBackgroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="GridRoot.Background" Value="{ThemeResource SimpleCardBackgroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="GridRoot.Background" Value="{ThemeResource SimpleCardBackgroundDisabled}" />
										<Setter Target="GridRoot.Opacity" Value="0.38" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
							<VisualStateGroup x:Name="FocusStates">
								<VisualState x:Name="Focused" />
								<VisualState x:Name="PointerFocused" />
								<VisualState x:Name="Unfocused" />
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<Style
		x:Key="SimpleFilledCardStyle"
		BasedOn="{StaticResource SimpleBaseCardStyle}"
		TargetType="utu:Card">
		<Setter Property="BorderThickness" Value="0" />
	</Style>

	<Style
		x:Key="SimpleOutlinedCardStyle"
		BasedOn="{StaticResource SimpleBaseCardStyle}"
		TargetType="utu:Card">
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleCardBorderBrush}" />
		<Setter Property="BorderThickness" Value="{StaticResource SimpleCardBorderThickness}" />
	</Style>

	<Style
		x:Key="SimpleElevatedCardStyle"
		BasedOn="{StaticResource SimpleOutlinedCardStyle}"
		TargetType="utu:Card" />

	<Style
		x:Key="SimpleAvatarFilledCardStyle"
		BasedOn="{StaticResource SimpleFilledCardStyle}"
		TargetType="utu:Card" />

	<Style
		x:Key="SimpleAvatarOutlinedCardStyle"
		BasedOn="{StaticResource SimpleOutlinedCardStyle}"
		TargetType="utu:Card" />

	<Style
		x:Key="SimpleAvatarElevatedCardStyle"
		BasedOn="{StaticResource SimpleOutlinedCardStyle}"
		TargetType="utu:Card" />

	<Style
		x:Key="SimpleSmallMediaFilledCardStyle"
		BasedOn="{StaticResource SimpleFilledCardStyle}"
		TargetType="utu:Card" />

	<Style
		x:Key="SimpleSmallMediaOutlinedCardStyle"
		BasedOn="{StaticResource SimpleOutlinedCardStyle}"
		TargetType="utu:Card" />

	<Style
		x:Key="SimpleSmallMediaElevatedCardStyle"
		BasedOn="{StaticResource SimpleOutlinedCardStyle}"
		TargetType="utu:Card" />

	<DataTemplate x:Key="SimpleBrandHeaderContentTemplate">
		<TextBlock
			Margin="0,0,0,8"
			FontSize="24"
			FontWeight="SemiBold"
			Foreground="{ThemeResource SimpleBrandCardForeground}"
			MaxLines="1"
			Text="{Binding}" />
	</DataTemplate>

	<DataTemplate x:Key="SimpleBrandSubHeaderContentTemplate">
		<TextBlock
			FontSize="16"
			Foreground="{ThemeResource SimpleBrandCardSecondaryForeground}"
			MaxLines="2"
			Text="{Binding}" />
	</DataTemplate>

	<DataTemplate x:Key="SimpleBrandSupportingContentTemplate">
		<TextBlock
			FontSize="16"
			Foreground="{ThemeResource SimpleBrandCardSecondaryForeground}"
			Text="{Binding}"
			TextWrapping="Wrap" />
	</DataTemplate>

	<Style
		x:Key="SimpleBrandFilledCardStyle"
		BasedOn="{StaticResource SimpleFilledCardStyle}"
		TargetType="utu:Card">
		<Setter Property="Background" Value="{ThemeResource SimpleBrandCardBackground}" />
		<Setter Property="HeaderContentTemplate" Value="{StaticResource SimpleBrandHeaderContentTemplate}" />
		<Setter Property="SubHeaderContentTemplate" Value="{StaticResource SimpleBrandSubHeaderContentTemplate}" />
		<Setter Property="SupportingContentTemplate" Value="{StaticResource SimpleBrandSupportingContentTemplate}" />
	</Style>

	<Style
		x:Key="SimpleBrandOutlinedCardStyle"
		BasedOn="{StaticResource SimpleOutlinedCardStyle}"
		TargetType="utu:Card">
		<Setter Property="Background" Value="{ThemeResource SimpleBrandCardBackground}" />
		<Setter Property="HeaderContentTemplate" Value="{StaticResource SimpleBrandHeaderContentTemplate}" />
		<Setter Property="SubHeaderContentTemplate" Value="{StaticResource SimpleBrandSubHeaderContentTemplate}" />
		<Setter Property="SupportingContentTemplate" Value="{StaticResource SimpleBrandSupportingContentTemplate}" />
	</Style>

</ResourceDictionary>
