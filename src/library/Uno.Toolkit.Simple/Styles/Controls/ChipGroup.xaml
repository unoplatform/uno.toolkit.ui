<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:utu="using:Uno.Toolkit.UI">

	<ItemsPanelTemplate x:Key="SimpleHorizontalChipGroupItemsPanel">
		<StackPanel Orientation="Horizontal" Spacing="8" />
	</ItemsPanelTemplate>

	<Style x:Key="SimpleBaseChipGroupStyle" TargetType="utu:ChipGroup">
		<Setter Property="ItemsPanel" Value="{StaticResource SimpleHorizontalChipGroupItemsPanel}" />
	</Style>

	<Style
		x:Key="SimpleInputChipGroupStyle"
		BasedOn="{StaticResource SimpleBaseChipGroupStyle}"
		TargetType="utu:ChipGroup">
		<Setter Property="ItemContainerStyle" Value="{StaticResource SimpleInputChipStyle}" />
		<Setter Property="CanRemove" Value="True" />
		<Setter Property="SelectionMode" Value="Multiple" />
	</Style>

	<Style
		x:Key="SimpleFilterChipGroupStyle"
		BasedOn="{StaticResource SimpleBaseChipGroupStyle}"
		TargetType="utu:ChipGroup">
		<Setter Property="ItemContainerStyle" Value="{StaticResource SimpleFilterChipStyle}" />
		<Setter Property="CanRemove" Value="False" />
		<Setter Property="SelectionMode" Value="Multiple" />
	</Style>

	<Style
		x:Key="SimpleElevatedFilterChipGroupStyle"
		BasedOn="{StaticResource SimpleFilterChipGroupStyle}"
		TargetType="utu:ChipGroup" />

	<Style
		x:Key="SimpleSuggestionChipGroupStyle"
		BasedOn="{StaticResource SimpleBaseChipGroupStyle}"
		TargetType="utu:ChipGroup">
		<Setter Property="ItemContainerStyle" Value="{StaticResource SimpleSuggestionChipStyle}" />
		<Setter Property="CanRemove" Value="False" />
		<Setter Property="SelectionMode" Value="Single" />
	</Style>

	<Style
		x:Key="SimpleElevatedSuggestionChipGroupStyle"
		BasedOn="{StaticResource SimpleSuggestionChipGroupStyle}"
		TargetType="utu:ChipGroup" />

	<Style
		x:Key="SimpleAssistChipGroupStyle"
		BasedOn="{StaticResource SimpleBaseChipGroupStyle}"
		TargetType="utu:ChipGroup">
		<Setter Property="ItemContainerStyle" Value="{StaticResource SimpleAssistChipStyle}" />
		<Setter Property="CanRemove" Value="False" />
		<Setter Property="SelectionMode" Value="None" />
	</Style>

	<Style
		x:Key="SimpleElevatedAssistChipGroupStyle"
		BasedOn="{StaticResource SimpleAssistChipGroupStyle}"
		TargetType="utu:ChipGroup" />

</ResourceDictionary>
