<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Uno.Sdk">
	<Import Project="..\..\tfm-common-winui.props" />

	<!--
	Adding project references to this project requires some manual adjustments.
	Please see https://github.com/unoplatform/uno/issues/3909 for more details.
	-->
	<PropertyGroup>
		<UnoSingleProject>true</UnoSingleProject>
		<DefineConstants>$(DefineConstants);IS_WINUI</DefineConstants>
		<!-- Ensures the .xr.xml files are generated in a proper layout folder -->
		<GenerateLibraryLayout>true</GenerateLibraryLayout>
		<AssemblyName>Uno.Toolkit.WinUI.Cupertino</AssemblyName>
		<RootNamespace>Uno.Toolkit.UI.Cupertino</RootNamespace>
		<PackageId>Uno.Toolkit.WinUI.Cupertino</PackageId>
		<UnoXamlResourcesTrimming Condition="'$(OS)'=='Windows_NT' or '$(MSBuildRuntimeType)'=='Core'">true</UnoXamlResourcesTrimming>
		<UnoFeatures>Cupertino</UnoFeatures>
	</PropertyGroup>

	<ItemGroup Condition="$(_IsWindowsWinUI)">
		<Page Remove="Generated\*.xaml" />
	</ItemGroup>

	<ItemGroup>
		<UpToDateCheckInput Include="**\*.xaml" Exclude="bin\**\*.xaml;obj\**\*.xaml" />
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\..\Uno.Toolkit.UI\Uno.Toolkit.WinUI.csproj" />
	</ItemGroup>

	<ItemGroup Condition="'$(ImplicitUsings)'=='true' OR '$(ImplicitUsings)'=='enable'">
		<Using Include="Uno.Toolkit.UI.Cupertino" />
	</ItemGroup>

	<Import Project="..\..\winappsdk-workaround.targets" />
	<Import Project="xamlmerge-cupertino.props" />
</Project>
